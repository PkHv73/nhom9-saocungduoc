FROM python:3.12-slim

WORKDIR /app

COPY requirements_jira.txt .
RUN pip install --no-cache-dir -r requirements_jira.txt

COPY jira_agent.py jira_main.py ./

EXPOSE 8080

ENV LLM_MODEL=qwen/qwen3-5-27b \
    MAX_TOKENS=4096 \
    LOG_LEVEL=INFO \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

CMD ["python", "jira_main.py"]
